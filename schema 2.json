                "description": "Phương thức xác thực chấm công"
              },
              "createdAt": {
                "type": "string",
                "format": "date-time"
              },
              "updatedAt": {
                "type": "string",
                "format": "date-time"
              }
            },
            "required": ["_id", "employee_did", "ngay", "loai_ngay", "xac_thuc_qua", "createdAt", "updatedAt"],
            "additionalProperties": false
          },
          "jsonSample": [
            {
              "_id": "att_672c8a2c5b8e4e0e8f2a1b3d",
