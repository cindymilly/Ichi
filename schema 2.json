              "loai_ngay": "Ngày thường",
              "ghi_chu": null,
              "xac_thuc_qua": "QR Code",
              "createdAt": "2025-10-12T08:30:00Z",
              "updatedAt": "2025-10-12T17:35:00Z"
            }
          ]
        }
      },
      "private": {
        "node_function": {
          "edge": [
            {
              "pipeline": [
                {
                  "$merge": {
                    "into": "cham_cong",
                    "on": ["employee_did", "ngay"],
                    "whenMatched": "merge",
                    "whenNotMatched": "insert"
                  }
                }
              ],
              "purpose": "Ghi lại dữ liệu chấm công hàng ngày của nhân viên. Hỗ trợ xác thực qua QR Code vật lý."
            }
