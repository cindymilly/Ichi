                "format": "time",
                "description": "Giờ check-out (HH:MM:SS)"
              },
              "tong_gio_lam": {
                "type": ["number", "null"],
                "minimum": 0,
                "description": "Tổng số giờ làm việc trong ngày"
              },
              "loai_ngay": {
                "type": "string",
                "enum": ["Ngày thường", "Cuối tuần", "Lễ", "Nghỉ phép", "Nghỉ ốm", "Vắng không phép"],
